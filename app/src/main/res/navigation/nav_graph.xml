<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/listFragment">

    <fragment
        android:id="@+id/listFragment"
        android:name="com.agusstkd.fasekotlin.ui.home.list.ListFragment"
        android:label="FirstFragment" >
        <action
            android:id="@+id/action_firstFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>
    <fragment
        android:id="@+id/detailFragment"
        android:name="com.agusstkd.fasekotlin.ui.home.detail.DetailFragment"
        android:label="fragment_detail"
        tools:layout="@layout/fragment_detail" >
        <action
            android:id="@+id/action_detailFragment_to_firstFragment"
            app:destination="@id/listFragment" />
    </fragment>
    <fragment
        android:id="@+id/secondFragment"
        android:name="com.agusstkd.fasekotlin.fragments.SecondFragment"
        android:label="SecondFragment" />
    <fragment
        android:id="@+id/thirdFragment"
        android:name="com.agusstkd.fasekotlin.fragments.ThirdFragment"
        android:label="ThirdFragment" />
</navigation>